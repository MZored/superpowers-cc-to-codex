{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary", "files_changed", "tests", "concerns"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["DONE", "DONE_WITH_CONCERNS", "BLOCKED", "NEEDS_CONTEXT"]
    },
    "summary": { "type": "string" },
    "files_changed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "result"],
        "properties": {
          "command": { "type": "string" },
          "result": { "type": "string" }
        }
      }
    },
    "red_green_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["behavior", "red", "green"],
        "properties": {
          "behavior": { "type": "string" },
          "red": { "type": "string" },
          "green": { "type": "string" },
          "refactor": { "type": "string" }
        }
      }
    },
    "concerns": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
