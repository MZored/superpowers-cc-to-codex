{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mzored/superpowers-cc-to-codex/schemas/spec-review.schema.json",
  "version": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "issues"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["APPROVED", "ISSUES_FOUND"]
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "line", "issue", "severity"],
        "properties": {
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "issue": { "type": "string" },
          "severity": { "type": "string", "enum": ["important", "critical"] }
        }
      }
    }
  }
}
